{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and overall performance metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "targetCompany": { "type": "string" },
        "avgScore": { "type": "number" },
        "totalInterviews": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Interview": {
      "title": "Interview Session",
      "description": "Stores a single mock interview session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["Technical", "HR", "Rapid Fire", "Company-specific"] },
        "company": { "type": "string" },
        "status": { "type": "string", "enum": ["ongoing", "completed"] },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" },
              "feedback": { "type": "string" },
              "score": { "type": "number" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "overallScore": { "type": "number" },
        "evaluation": {
          "type": "object",
          "properties": {
            "communication": { "type": "number" },
            "technical": { "type": "number" },
            "confidence": { "type": "number" },
            "summary": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "status"]
    },
    "Weakness": {
      "title": "Weakness Tracker",
      "description": "Tracks specific topics where the user needs improvement.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "frequency": { "type": "number" },
        "lastEncountered": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic"]
    },
    "PrepPlan": {
      "title": "Preparation Plan",
      "description": "A day-wise preparation plan generated by the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "target": { "type": "string" },
        "durationDays": { "type": "number" },
        "plan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "number" },
              "topics": { "type": "array", "items": { "type": "string" } },
              "tasks": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "target"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/interviews/{interviewId}": {
      "schema": "Interview",
      "description": "Mock interview sessions."
    },
    "/weaknesses/{weaknessId}": {
      "schema": "Weakness",
      "description": "User weakness tracking."
    },
    "/plans/{planId}": {
      "schema": "PrepPlan",
      "description": "AI-generated prep plans."
    }
  }
}
